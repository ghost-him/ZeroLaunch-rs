{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "zerolaunch-rs",
  "version": "1.0.0",
  "identifier": "com.zerolaunch-rs.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:12345",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "zerolaunch-rs",
        "visible": false,
        "fullscreen": false,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": true,
        "dragDropEnabled": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": "default-src 'self' zlplugin:; script-src 'self' zlplugin: 'unsafe-inline'; style-src 'self' 'unsafe-inline' zlplugin:; connect-src 'self' http://127.0.0.1:* zlplugin:; frame-src zlplugin: data:; img-src 'self' data: zlplugin:; font-src 'self' data: zlplugin:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "resources": [
      "icons/",
      "locales/",
      "models/readme.md"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/web_pages.png",
      "icons/tips.png",
      "icons/terminal.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "zerolaunch-rs"
        ]
      }
    }
  }
}